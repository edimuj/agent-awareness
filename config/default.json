{
  "activity": {
    "idleTimeoutMinutes": 10
  },
  "policy": {
    "maxCharsSessionStart": 800,
    "maxCharsPrompt": 500,
    "showPluginNames": true
  },
  "plugins": {
    "time-date": {
      "enabled": true,
      "timezone": "auto",
      "showTime": true,
      "showTimezone": true,
      "showDay": true,
      "showDate": true,
      "showWeekNumber": true,
      "showBusinessHours": true,
      "businessHours": { "start": 8, "end": 17 },
      "triggers": {
        "session-start": "full",
        "change:hour": "compact"
      }
    }
  }
}
