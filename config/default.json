{
  "plugins": {
    "time-date": {
      "enabled": true,
      "timezone": "auto",
      "showTime": true,
      "showTimezone": true,
      "showDay": true,
      "showDate": true,
      "showWeekNumber": true,
      "showBusinessHours": true,
      "businessHours": { "start": 9, "end": 17 },
      "triggers": {
        "session-start": "full",
        "change:hour": "compact"
      }
    },
    "quota": {
      "enabled": true,
      "showSession": true,
      "showBurst": true,
      "showWeekly": true,
      "showResetTime": true,
      "burstSignals": [
        { "pct": 80, "message": "CONSERVE" },
        { "pct": 60, "message": "consider delegating" }
      ],
      "weeklySignals": [
        { "pct": 90, "message": "WARNING" }
      ],
      "triggers": {
        "session-start": true,
        "interval:10m": true
      }
    },
    "system": {
      "enabled": true,
      "diskPath": "/",
      "showDisk": true,
      "showMemory": true,
      "showLoad": true,
      "onlyWhenWarning": false,
      "thresholds": {
        "diskPct": 80,
        "memoryPct": 80,
        "loadPerCpu": 2.0
      },
      "messages": {
        "disk": "WARNING",
        "memory": "WARNING",
        "load": "HIGH"
      },
      "triggers": {
        "session-start": true,
        "interval:15m": true
      }
    },
    "weather": {
      "enabled": true,
      "showTemp": true,
      "showFeelsLike": true,
      "showCondition": true,
      "showWind": true,
      "showSunset": true,
      "feelsLikeDelta": 3,
      "onlyWhenChanged": false,
      "triggers": {
        "session-start": true,
        "change:hour": true
      }
    }
  }
}
