{
  "name": "agent-awareness",
  "version": "0.8.5",
  "description": "Modular awareness plugins for AI coding agents",
  "type": "module",
  "bin": {
    "agent-awareness": "dist/cli.js"
  },
  "types": "./types/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./plugins/*": {
      "types": "./types/plugins/*.d.ts",
      "default": "./dist/plugins/*.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist types claude-plugin/dist codex-plugin/dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && cp -r dist claude-plugin/dist && cp -r dist codex-plugin/dist",
    "prepublishOnly": "npm run build",
    "test": "node --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "session-start": "node hooks/session-start.ts",
    "prompt": "node hooks/prompt-submit.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "awareness",
    "claude-code",
    "plugin"
  ],
  "files": [
    "dist/",
    "types/",
    "src/",
    "hooks/",
    "config/",
    "claude-plugin/",
    ".claude-plugin/",
    "codex-plugin/",
    "docs/",
    "README.md"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  }
}
