{
  "name": "agent-awareness",
  "version": "0.1.0",
  "description": "Modular awareness plugins for AI coding agents",
  "type": "module",
  "bin": {
    "agent-awareness": "./src/cli.ts"
  },
  "types": "./types/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/core/index.d.ts",
      "default": "./src/core/index.ts"
    },
    "./plugins/*": {
      "types": "./types/plugins/*.d.ts",
      "default": "./src/plugins/*.ts"
    }
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:types",
    "test": "node --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "session-start": "node hooks/session-start.ts",
    "prompt": "node hooks/prompt-submit.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "awareness",
    "claude-code",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  }
}
